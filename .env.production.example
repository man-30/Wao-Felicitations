# ============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE — WAOOO FELICITATIONS v2.0
# Copy to `.env.production` and replace ALL placeholders.
# Never commit `.env.production` with real secrets.
# ============================================================================

# Neon main branch (direct URL only for migrations / admin tasks)
DATABASE_URL="postgresql://neonuser:REPLACE_MAIN_DB_PASSWORD@main-xxxxx.neon.tech:5432/neondb?sslmode=require"

# Neon pooled URL (must be used by application runtime)
DATABASE_URL_POOLED="postgresql://neonuser:REPLACE_MAIN_DB_PASSWORD@main-xxxxx-pooler.neon.tech:5432/neondb?sslmode=require"

# Security
JWT_SECRET="REPLACE_WITH_32_PLUS_RANDOM_CHARACTERS"
ENCRYPTION_KEY="REPLACE_WITH_32_PLUS_RANDOM_CHARACTERS"

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# CORS
CORS_ORIGIN="https://www.wao-felicitations.com"

# Logging
LOG_LEVEL=info
LOG_FILE="/var/log/waooo-felicitations/app.log"

# Optional observability
SENTRY_DSN=""
SENTRY_ENVIRONMENT=production
