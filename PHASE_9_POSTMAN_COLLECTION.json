        {
          "name": "Test 5: Token Verification & Decoding",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Token can be decoded', function () {",
                  "    var token = pm.collectionVariables.get('token');",
                  "    var parts = token.split('.');",
                  "    pm.expect(parts.length).to.equal(3);",
                  "    var payload = JSON.parse(atob(parts[1]));",
                  "    pm.expect(payload).to.have.property('id');",
                  "    pm.expect(payload).to.have.property('email');",
                  "    pm.expect(payload).to.have.property('role');",
                  "});",
                  "",
                  "pm.test('✅ Token has expiration', function () {",
                  "    var token = pm.collectionVariables.get('token');",
                  "    var parts = token.split('.');",
                  "    var payload = JSON.parse(atob(parts[1]));",
                  "    pm.expect(payload).to.have.property('exp');",
                  "});"
                ]
