# ─── DATABASE ─────────────────────────────────────────────────────────────
# Connexion directe — À utiliser pour les migrations Prisma
DATABASE_URL="postgresql://username:password@host:5432/dbname?sslmode=require&channel_binding=require"

# Connexion poolée — À utiliser pour l'application (Neon)
DATABASE_URL_POOLED="postgresql://username:password@pooler.host:5432/dbname?sslmode=require&channel_binding=require"

# ─── APPLICATION ──────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API (optionnel pour backend) ─────────────────────────────────────────
API_URL=http://localhost:3000
API_PORT=3000

# ─── JWT (si authentification requise) ────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# ─── MAIL (optionnel pour notifications) ─────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=user@example.com
MAIL_PASS=password
MAIL_FROM=noreply@waofelicitations.com
