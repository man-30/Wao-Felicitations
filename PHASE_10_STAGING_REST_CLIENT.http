@baseUrl = http://localhost:3001
@contentType = application/json

# -------------------------------------------------------------------------
# Mode d'emploi rapide (VS Code REST Client)
# 1) Exécute "Login Admin" puis "Login Cashier"
# 2) Lance Test 1 (Create Client)
# 3) Lance Test 2, 3, 4, 5 : les IDs sont repris automatiquement
# 4) Puis lance Test 6 et 7
# -------------------------------------------------------------------------

### Login Admin
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@staging.test",
  "password": "AdminStaging123!"
}

### Login Cashier
# @name loginCashier
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "cashier@staging.test",
  "password": "CashierStaging123!"
}

### Test 1: Create Client
# @name createClient
POST {{baseUrl}}/api/clients
Content-Type: {{contentType}}
Authorization: Bearer {{loginAdmin.response.body.token}}

{
  "name": "Apprenant Test Phase 10",
  "type": "apprenant",
  "phone": "+243812345678",
  "address": "Kinshasa, Gombe",
  "commercialId": "staging-u-commercial"
}

### Test 2: Get Client (ID auto depuis Test 1)
GET {{baseUrl}}/api/clients/{{createClient.response.body.id}}
Authorization: Bearer {{loginAdmin.response.body.token}}

### Test 3: Record Deposit (ID auto depuis Test 1)
# @name recordDeposit
POST {{baseUrl}}/api/transactions
Content-Type: {{contentType}}
Authorization: Bearer {{loginCashier.response.body.token}}

{
  "clientId": "{{createClient.response.body.id}}",
  "clientName": "Apprenant Test Phase 10",
  "amount": 50000,
  "type": "depot",
  "collectedBy": "staging-u-cashier",
  "collectedByName": "Staging Cashier",
  "description": "Test deposit Phase 10"
}

### Test 4: Validate Transaction (ID auto depuis Test 3)
PUT {{baseUrl}}/api/transactions/{{recordDeposit.response.body.transaction.id}}/validate
Content-Type: {{contentType}}
Authorization: Bearer {{loginAdmin.response.body.token}}

{
}

### Test 5: Record Cotisation (ID auto depuis Test 1)
POST {{baseUrl}}/api/cotisations
Content-Type: {{contentType}}
Authorization: Bearer {{loginCashier.response.body.token}}

{
  "clientId": "{{createClient.response.body.id}}",
  "amount": 2500,
  "type": "cotisation",
  "date": "2026-05-09",
  "collectedBy": "staging-u-cashier",
  "collectedByName": "Staging Cashier"
}

### Test 6: Get Audit Logs
GET {{baseUrl}}/api/audit-logs
Authorization: Bearer {{loginAdmin.response.body.token}}

### Test 7: Get Dashboard Stats
GET {{baseUrl}}/api/dashboard/stats
Authorization: Bearer {{loginAdmin.response.body.token}}