{
  "info": {
    "name": "Phase 10 - Staging API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. AUTH",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "});",
                  "pm.environment.set('token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@staging.test\", \"password\": \"AdminStaging123!\"}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Cashier",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.environment.set('cashier_token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"cashier@staging.test\", \"password\": \"CashierStaging123!\"}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. CLIENTS",
      "item": [
        {
          "name": "Create Client Apprenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('clientId', jsonData.id);",
                  "pm.test('Client has membership code', function () {",
                  "    pm.expect(jsonData.membershipCode).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Apprenant Test Phase 10\", \"type\": \"apprenant\", \"phone\": \"+243812345678\", \"address\": \"Kinshasa, Gombe\", \"assignedCommercialId\": \"staging-u-commercial\"}"
            },
            "url": {
              "raw": "http://localhost:3001/api/clients",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "clients"]
            }
          }
        },
        {
          "name": "Get Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Client exists', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/clients/{{clientId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "clients", "{{clientId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "3. TRANSACTIONS",
      "item": [
        {
          "name": "Record Deposit",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('transactionId', jsonData.id);",
                  "pm.test('Transaction pending approval', function () {",
                  "    pm.expect(jsonData.status).to.equal('en_attente');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{cashier_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"clientId\": \"{{clientId}}\", \"clientName\": \"Apprenant Test Phase 10\", \"amount\": 50000, \"type\": \"depot\", \"collectedBy\": \"staging-u-cashier\", \"collectedByName\": \"Staging Cashier\", \"description\": \"Test deposit phase 10\"}"
            },
            "url": {
              "raw": "http://localhost:3001/api/transactions",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "transactions"]
            }
          }
        },
        {
          "name": "Validate Transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Transaction approved', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal('approuve');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "http://localhost:3001/api/transactions/{{transactionId}}/validate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "transactions", "{{transactionId}}", "validate"]
            }
          }
        }
      ]
    },
